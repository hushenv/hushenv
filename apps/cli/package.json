{
  "name": "hushenv",
  "version": "0.2.0",
  "description": "Local secret manager for the agent era - encrypted vault, {hushenv.X} refs in .env, plaintext only at runtime.",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hushenv/hushenv.git",
    "directory": "apps/cli"
  },
  "homepage": "https://github.com/hushenv/hushenv#readme",
  "bugs": {
    "url": "https://github.com/hushenv/hushenv/issues"
  },
  "keywords": [
    "secrets",
    "env",
    "dotenv",
    "vault",
    "keychain",
    "security",
    "cli"
  ],
  "bin": {
    "hushenv": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepack": "node -e \"require('fs').copyFileSync('../../README.md','README.md')\"",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@hushenv/vault-core": "workspace:*",
    "@inquirer/prompts": "^8.5.0",
    "commander": "^15.0.0",
    "cross-spawn": "^7.0.6",
    "dotenv": "^17.4.0"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.10.0",
    "tsx": "^4.22.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9"
  }
}
