    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@hushenv/vault-core": "workspace:*",
    "@inquirer/prompts": "^8.5.0",
    "commander": "^15.0.0",
    "cross-spawn": "^7.0.6",
    "dotenv": "^17.4.0"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.10.0",
    "tsx": "^4.22.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0"
  }
}